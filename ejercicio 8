#include <iostream>
using namespace std;

int main() {
    int numeros[8];
    int *ptr = numeros;
    int contador = 0;

    cout << "Ingrese 8 numeros:" << endl;

    for (int i = 0; i < 8; i++) {
        cin >> *(ptr + i);
    }

    for (int i = 0; i < 8; i++) {
        if (*(ptr + i) % 2 == 0) {
            contador++;
        }
    }

    cout << "Cantidad de numeros pares: " << contador << endl;

    return 0;
}
