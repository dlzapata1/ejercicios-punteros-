#include <iostream>
using namespace std;

int main() {
    int numeros[5];
    int *ptr = numeros;
    int suma = 0;
    float promedio;

    cout << "Ingrese 5 numeros:" << endl;

    for (int i = 0; i < 5; i++) {
        cin >> *(ptr + i);
    }

    for (int i = 0; i < 5; i++) {
        suma += *(ptr + i);
    }

    promedio = (float)suma / 5;

    cout << "La suma es: " << suma << endl;
    cout << "El promedio es: " << promedio << endl;

    return 0;
}
