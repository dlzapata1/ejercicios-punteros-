#include <iostream>
using namespace std;

int main() {
    int num1, num2;
    int *ptr1, *ptr2;

    cout << "Ingrese el primer numero: ";
    cin >> num1;

    cout << "Ingrese el segundo numero: ";
    cin >> num2;

    ptr1 = &num1;
    ptr2 = &num2;

    cout << "La multiplicacion es: " << (*ptr1) * (*ptr2) << endl;

    return 0;
}
