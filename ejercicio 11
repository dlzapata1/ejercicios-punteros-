#include <iostream>
using namespace std;

int main() {
    int numeros[5];
    int *ptr = numeros;
    int aux;

    cout << "Ingrese 5 numeros:" << endl;

    for (int i = 0; i < 5; i++) {
        cin >> *(ptr + i);
    }

    for (int i = 0; i < 4; i++) {
        for (int j = i + 1; j < 5; j++) {
            if (*(ptr + i) > *(ptr + j)) {
                aux = *(ptr + i);
                *(ptr + i) = *(ptr + j);
                *(ptr + j) = aux;
            }
        }
    }

    cout << "\nArreglo ordenado:" << endl;

    for (int i = 0; i < 5; i++) {
        cout << *(ptr + i) << " ";
    }

    return 0;
}
