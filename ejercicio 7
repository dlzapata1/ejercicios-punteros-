#include <iostream>
using namespace std;

int main() {
    int numeros[5];
    int *ptr = numeros;

    cout << "Ingrese 5 numeros:" << endl;

    for (int i = 0; i < 5; i++) {
        cin >> *(ptr + i);
    }

    cout << "\nArreglo en orden inverso:" << endl;

    for (int i = 4; i >= 0; i--) {
        cout << *(ptr + i) << " ";
    }

    return 0;
}
