#include <iostream>
using namespace std;

int main() {
    int numeros[6];
    int *ptr = numeros;
    int suma = 0;

    cout << "Ingrese 6 numeros:" << endl;

    for(int i = 0; i < 6; i++) {
        cin >> *(ptr + i);
    }

    for(int i = 0; i < 6; i++) {
        suma += *(ptr + i);
    }

    cout << "La suma es: " << suma << endl;

    return 0;
}
