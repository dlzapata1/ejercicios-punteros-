#include <iostream>
using namespace std;

int main() {
    char palabra[50];
    char *ptr;
    int vocales = 0;

    cout << "Ingrese una palabra: ";
    cin >> palabra;

    ptr = palabra;

    while (*ptr != '\0') {
        if (*ptr == 'a' || *ptr == 'e' || *ptr == 'i' ||
            *ptr == 'o' || *ptr == 'u' ||
            *ptr == 'A' || *ptr == 'E' || *ptr == 'I' ||
            *ptr == 'O' || *ptr == 'U') {
            vocales++;
        }
        ptr++;
    }

    cout << "Cantidad de vocales: " << vocales << endl;

    return 0;
}
