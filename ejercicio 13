#include <iostream>
using namespace std;

void sumar(int *a, int *b) {
    cout << "La suma es: " << (*a + *b) << endl;
}

int main() {
    int num1, num2;

    cout << "Ingrese el primer numero: ";
    cin >> num1;

    cout << "Ingrese el segundo numero: ";
    cin >> num2;

    sumar(&num1, &num2);

    return 0;
}
