#include <iostream>
using namespace std;

int main() {
    int numeros[5];
    int *ptr = numeros;

    cout << "Ingrese 5 numeros:" << endl;

    for(int i = 0; i < 5; i++) {
        cin >> *(ptr + i);
    }

    cout << "\nLos numeros ingresados son:" << endl;

    for(int i = 0; i < 5; i++) {
        cout << *(ptr + i) << " ";
    }

    return 0;
}
