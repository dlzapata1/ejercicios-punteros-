#include <iostream>
using namespace std;

int main() {
    int arreglo1[5];
    int arreglo2[5];

    int *ptr1 = arreglo1;
    int *ptr2 = arreglo2;

    cout << "Ingrese 5 numeros:" << endl;

    for (int i = 0; i < 5; i++) {
        cin >> *(ptr1 + i);
    }

    for (int i = 0; i < 5; i++) {
        *(ptr2 + i) = *(ptr1 + i);
    }

    cout << "\nContenido del segundo arreglo:" << endl;

    for (int i = 0; i < 5; i++) {
        cout << *(ptr2 + i) << " ";
    }

    return 0;
}
