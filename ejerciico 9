#include <iostream>
using namespace std;

int main() {
    int numeros[6];
    int *ptr = numeros;
    int buscar;
    bool encontrado = false;

    cout << "Ingrese 6 numeros:" << endl;

    for (int i = 0; i < 6; i++) {
        cin >> *(ptr + i);
    }

    cout << "Ingrese el numero que desea buscar: ";
    cin >> buscar;

    for (int i = 0; i < 6; i++) {
        if (*(ptr + i) == buscar) {
            encontrado = true;
            break;
        }
    }

    if (encontrado) {
        cout << "El numero se encuentra en el arreglo." << endl;
    } else {
        cout << "El numero no se encuentra en el arreglo." << endl;
    }

    return 0;
}
