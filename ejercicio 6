#include <iostream>
using namespace std;

int main() {
    int numeros[5];
    int *ptr = numeros;

    cout << "Ingrese 5 numeros:" << endl;

    for(int i = 0; i < 5; i++) {
        cin >> *(ptr + i);
    }

    int mayor = *ptr;

    for(int i = 1; i < 5; i++) {
        if(*(ptr + i) > mayor) {
            mayor = *(ptr + i);
        }
    }

    cout << "El numero mayor es: " << mayor << endl;

    return 0;
}
